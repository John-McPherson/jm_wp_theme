{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "jm/hero",
  "version": "0.1.0",
  "title": "Hero",
  "category": "jm-blocks",
  "icon": "layout",
  "description": "Hero section with heading and image",
  "attributes": {
    "heading": {
      "type": "string",
