{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "jm/text-with-image",
  "version": "0.1.0",
  "title": "Text with Image",
  "category": "jm-blocks",
  "icon": "layout",
  "description": "Text section with image",
  "attributes": {
    "label": {
      "type": "string",
      "default": ""
    },
    "palette": {
      "type": "string",
      "default": "jm-palette--default"
    },
    "heading": {
      "type": "string",
      "default": ""
    },
    "text": {
      "type": "string",
      "default": ""
    },
    "link": {
      "type": "object",
      "default": {
        "url": "",
        "label": "",
        "target": "",
        "rel": ""
      }
    },
    "linkText": {
      "type": "string",
      "default": ""
    },
    "imageId": {
      "type": "number",
      "default": 0
    },
    "imageUrl": {
      "type": "string",
      "default": ""
    }
  },
  "example": {},
  "supports": {},
  "textdomain": "text-with-image",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js",
  "render": "file:./render.php"
}
